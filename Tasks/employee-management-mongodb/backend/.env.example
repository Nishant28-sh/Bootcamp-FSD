# ─────────────────────────────────────────────
#  Employee Management — Backend Environment
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Application ───────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbName>?retryWrites=true&w=majority&appName=<AppName>
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/employeeDB?retryWrites=true&w=majority&appName=YourAppName

# ── CORS ──────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Security ──────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# ── Logging ───────────────────────────────────
LOG_LEVEL=dev
